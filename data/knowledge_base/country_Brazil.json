  "national_documents": [
    {
      "id": "BR_NAT_SUBS_001",
      "dimension": "subsidies_incentives",
      "scope": "national",
      "content": "Brazil's distributed generation framework was established by ANEEL Resolution 482/2012, which introduced net metering (Sistema de Compensação de Energia Elétrica). Lei 14.300/2022 created the legal framework that preserves historical net metering benefits until 2045 for systems registered before 2023 (grandfathering), with a phased reduction of subsidies for new systems thereafter. This creates a time-sensitive window for new installations.",
      "sources": [
        {
          "organization": "Presidência da República",
          "document": "Lei 14.300/2022 — Marco Legal da Micro e Minigeração Distribuída",
          "url": "https://www.planalto.gov.br/ccivil_03/_ato2019-2022/2022/lei/l14300.htm",
          "accessed": "2026-04-10"
        },
        {
          "organization": "ANEEL",
          "document": "Resolução Normativa 482/2012",
          "url": "https://www.aneel.gov.br/",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {
        "grandfathering_until_year": 2045
      }
    },
    {
      "id": "BR_NAT_COST_001",
      "dimension": "cost_economics",
      "scope": "national",
      "content": "Brazil's distributed generation installed capacity exceeded 30 GW by end of 2024 per ANEEL SIGA, making Brazil the largest distributed-solar market in Latin America. CAPEX for utility-scale solar in Brazil ranges approximately USD 700–900/kW; distributed solar (rooftop/small ground-mount) typically USD 900–1,250/kW depending on size and region. Brazil has one of the highest industrial electricity tariffs in Latin America, structurally favoring distributed solar economics.",
      "sources": [
        {
          "organization": "ANEEL",
          "document": "SIGA — Sistema de Informações de Geração de Energia Elétrica",
          "url": "https://www.aneel.gov.br/siga",
          "accessed": "2026-04-10"
        },
        {
          "organization": "IRENA",
          "document": "Renewable Power Generation Costs 2023",
          "url": "https://www.irena.org/publications/2024/Sep/Renewable-Power-Generation-Costs-in-2023",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {
        "dg_installed_gw_end_2024_min": 30,
        "capex_utility_usd_per_kw_low": 700,
        "capex_utility_usd_per_kw_high": 900
      }
    },
    {
      "id": "BR_NAT_UTIL_001",
      "dimension": "utility_standards",
      "scope": "national",
      "content": "Brazil participates in the I-REC Standard voluntary market for Renewable Energy Certificates and has a domestic BVM (Brazilian Voluntary Market). There is no federally mandated RPS; instead, energy auctions (A-4, A-6) organized by EPE/MME procure renewable capacity by contract. Large consumers in the free market (Mercado Livre) increasingly procure renewable energy directly via PPAs.",
      "sources": [
        {
          "organization": "I-REC Standard",
          "document": "Brazil Issuance Body",
          "url": "https://www.irecstandard.org/territory/brazil",
          "accessed": "2026-04-10"
        },
        {
          "organization": "EPE",
          "document": "Leilões de Energia Elétrica",
          "url": "https://www.epe.gov.br/pt/leiloes-de-energia",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {}
    },
    {
      "id": "BR_NAT_PUBLIC_001",
      "dimension": "public_comment",
      "scope": "national",
      "content": "Brazil requires environmental licensing by IBAMA (federal) or state environmental agencies. Distributed generation below 5 MW typically qualifies for simplified licensing. Large ground-mount solar requires public hearings (Audiência Pública) and community consultation. Historically, solar has faced less opposition than hydro or wind in Brazil, but land-tenure disputes can arise, particularly in the cerrado and caatinga biomes.",
      "sources": [
        {
          "organization": "IBAMA",
          "document": "Licenciamento Ambiental Federal",
          "url": "https://www.gov.br/ibama/pt-br/assuntos/laf/licenciamento-ambiental-federal",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {
        "simplified_licensing_threshold_mw": 5
      }
    },
    {
      "id": "BR_NAT_GRID_001",
      "dimension": "grid_access",
      "scope": "national",
      "content": "Brazil's grid is managed by ONS as a unified SIN (Sistema Interligado Nacional) with four subsystems: Southeast/Center-West, South, Northeast, and North. Grid interconnection for distributed generation (<5 MW) is handled by distribuidoras (local utilities like CEMIG, CPFL, COPEL, ENEL-SP) with timelines varying from 60–180 days post-application. Utility-scale requires ANEEL-EPE outorga and can take 12–24 months.",
      "sources": [
        {
          "organization": "ONS",
          "document": "Operação do Sistema Interligado Nacional",
          "url": "http://www.ons.org.br/",
          "accessed": "2026-04-10"
        },
        {
          "organization": "ANEEL",
          "document": "Procedimentos de Distribuição (PRODIST) Módulo 3",
          "url": "https://www.aneel.gov.br/prodist",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {
        "dg_interconnection_days_min": 60,
        "dg_interconnection_days_max": 180
      }
    },
    {
      "id": "BR_NAT_UNKNOWN_001",
      "dimension": "unknown_unknowns",
      "scope": "national",
      "content": "Brazil-specific risks: (1) hydro-dominant grid means solar curtailment is RARE historically, but grid modernization lags; (2) FX risk (BRL/USD) affects equipment imports — panels and inverters are primarily imported; (3) state-level ICMS tax treatment varies by CONFAZ agreement — some states still charge ICMS on the compensated energy portion, materially affecting DG payback; (4) Lei 14.300 transition creates uncertainty about the value of net metering post-2028 (phased subsidy reduction).",
      "sources": [
        {
          "organization": "CONFAZ",
          "document": "Convênio ICMS 16/2015 e alterações posteriores",
          "url": "https://www.confaz.fazenda.gov.br/legislacao/convenios",
          "accessed": "2026-04-10"
        }
      ],
      "confidence": "high",
      "last_verified": "2026-04-10",
      "data_points": {}
    },
